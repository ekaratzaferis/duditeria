---

<canvas id="flexy-canvas"></canvas>

<script>
  import { initFlexyEngine } from '../scripts/flexy-engine.js';

  const canvas = document.getElementById('flexy-canvas');
  if (canvas) {
    try {
      const dispose = initFlexyEngine(canvas);
      window.addEventListener('beforeunload', dispose, { once: true });
    } catch (err) {
      console.error('[flexy-engine] init failed:', err);
    }
  }
</script>

<style>
  canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    display: block;
    touch-action: pan-y;
  }
</style>
