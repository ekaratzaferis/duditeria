---

<canvas id="tess-extrude-canvas"></canvas>

<script>
  import { initTessExtrudeEngine } from '../scripts/tess-extrude-engine.js';

  const canvas = document.getElementById('tess-extrude-canvas');
  if (canvas) {
    try {
      const dispose = initTessExtrudeEngine(canvas);
      window.addEventListener('beforeunload', dispose, { once: true });
    } catch (err) {
      console.error('[tess-extrude-engine] init failed:', err);
    }
  }
</script>

<style>
  canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    display: block;
    touch-action: pan-y;
  }
</style>
