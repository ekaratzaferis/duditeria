---

<canvas id="stannis-canvas"></canvas>

<script>
  import { initStannisEngine } from '../scripts/stannis-engine.js';

  const canvas = document.getElementById('stannis-canvas');
  if (canvas) {
    try {
      const dispose = initStannisEngine(canvas);
      window.addEventListener('beforeunload', dispose, { once: true });
    } catch (err) {
      console.error('[stannis-engine] init failed:', err);
      document.body.style.background = '#800000';
    }
  } else {
    console.error('[stannis-engine] canvas not found');
    document.body.style.background = '#000080';
  }
</script>

<style>
  canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    display: block;
  }
</style>
