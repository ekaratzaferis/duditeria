---
import Base from '../layouts/Base.astro';
import HeroCanvas from '../components/HeroCanvas.astro';
import '../styles/global.css';
---

<Base>
  <HeroCanvas />

  <main>
    <h1 class="brand fade-in">Duditeria</h1>
    <h2 class="brand fade-in">Built simple. Built to last.</h2>

    <nav class="site-nav fade-in-delay-2" aria-label="Main navigation">
      <a href="/projects">Projects</a>
      <span class="sep" aria-hidden="true">·</span>
      <a href="/resume">Resume</a>
      <span class="sep" aria-hidden="true">·</span>
      <a href="/contact">Contact</a>
    </nav>
  </main>
</Base>

<style>
  main {
    position: relative;
    z-index: 1;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  /* Vignette — darkens edges so text stays legible over the light foggy sky */
  main::after {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 130% 100% at 50% 90%, transparent 15%, rgba(0, 0, 0, 1) 100%);
    pointer-events: none;
    z-index: 0;
  }

  .brand {
    font-family: 'Roboto Condensed', system-ui, sans-serif;
    font-size: clamp(2rem, 8vw, 5.5rem);
    font-weight: 300;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: #0a0a0a;
    text-indent: 0.38em; /* optical centering for tracked text */
    user-select: none;
    text-shadow:
      0 0 24px rgba(255, 255, 255, 0.85),
      0 0 48px rgba(255, 255, 255, 0.4);
  }

  h2.brand {
    font-size: clamp(0.75rem, 2.2vw, 1.5rem);
    letter-spacing: 0.14em;
    text-indent: 0.14em;
    font-weight: 300;
    margin-top: 0.6rem;
  }

  @media (max-width: 480px) {
    h2.brand {
      font-size: clamp(0.65rem, 4vw, 0.9rem);
      letter-spacing: 0.08em;
      text-indent: 0.08em;
    }
  }

  .site-nav {
    position: absolute;
    bottom: 2.5rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .site-nav a {
    font-size: 0.62rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #d8d8d0;
    transition: color 0.35s ease;
  }

  .site-nav a:hover {
    color: #ffffff;
  }

  .sep {
    color: #888;
    font-size: 0.6rem;
  }
</style>
