---
import Base from '../layouts/Base.astro';
import '../styles/global.css';
---

<Base
  title="Lab — Duditeria"
  description="Experimental 3D organism simulation."
>
  <canvas id="organism-canvas"></canvas>

  <script>
    import { initOrganismEngine } from '../scripts/organism-engine.js';
    const canvas = document.getElementById('organism-canvas');
    if (canvas) {
      const dispose = initOrganismEngine(canvas);
      window.addEventListener('beforeunload', dispose, { once: true });
    }
  </script>

  <header class="top-bar">
    <a href="/" class="back-link">← Duditeria</a>
    <span class="header-title">Lab</span>
  </header>
</Base>

<style>
  canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    display: block;
  }

  .top-bar {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 3rem;
    padding: 0 2rem;
    background: rgba(0, 0, 0, 0.6);
    border-bottom: 1px solid #1a1a1a;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .back-link {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #888;
    white-space: nowrap;
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .back-link:hover {
    color: #ccc;
  }

  .header-title {
    font-family: 'Roboto Condensed', system-ui, sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #f0f0f0;
  }
</style>
