---
import Base from '../layouts/Base.astro';
import '../styles/global.css';
---

<Base
  title="Lab — Duditeria"
  description="Experimental 3D organism simulation."
>
  <canvas id="organism-canvas"></canvas>

  <script>
    import { initOrganismEngine } from '../scripts/organism-engine.js';
    const canvas = document.getElementById('organism-canvas');
    if (canvas) {
      const dispose = initOrganismEngine(canvas);
      window.addEventListener('beforeunload', dispose, { once: true });
    }
  </script>

  <nav class="lab-nav">
    <a href="/">← Duditeria</a>
  </nav>
</Base>

<style>
  canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    display: block;
  }

  .lab-nav {
    position: fixed;
    top: 1.8rem;
    left: 2rem;
    z-index: 1;
  }

  .lab-nav a {
    font-family: 'Roboto Condensed', system-ui, sans-serif;
    font-size: 0.62rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #555;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .lab-nav a:hover {
    color: #f0f0f0;
  }
</style>
