---
import Base from '../layouts/Base.astro';
import '../styles/global.css';
---

<Base
  title="Contact — Alexandros Karatzaferis"
  description="Get in touch with Alexandros Karatzaferis — Software Architect and Principal Engineer."
  canonical="https://duditeria.com/contact"
>
  <nav class="back-nav">
    <a href="/">← Duditeria</a>
  </nav>

  <main>
    <div class="contact-wrap">

      <header class="contact-header">
        <h1 class="contact-title">Get in Touch</h1>
        <p class="contact-sub">Available for remote roles, architecture consulting, and interesting problems.</p>
      </header>

      <div class="contact-links">
        <a href="mailto:ekaratzaferis@gmail.com" class="link-card">
          <span class="link-label">Email</span>
          <span class="link-value">ekaratzaferis@gmail.com</span>
        </a>
        <a href="https://linkedin.com/in/ekaratzaferis" target="_blank" rel="noopener" class="link-card">
          <span class="link-label">LinkedIn</span>
          <span class="link-value">linkedin.com/in/ekaratzaferis</span>
        </a>
        <a href="https://github.com/ekaratzaferis" target="_blank" rel="noopener" class="link-card">
          <span class="link-label">GitHub</span>
          <span class="link-value">github.com/ekaratzaferis</span>
        </a>
      </div>

      <form class="contact-form" id="contact-form" novalidate>
        <div class="form-row">
          <div class="form-field">
            <label for="cf-name">Name</label>
            <input id="cf-name" name="name" type="text" autocomplete="name" placeholder="Your name" required />
          </div>
          <div class="form-field">
            <label for="cf-email">Email</label>
            <input id="cf-email" name="email" type="email" autocomplete="email" placeholder="your@email.com" required />
          </div>
        </div>
        <div class="form-field">
          <label for="cf-message">Message</label>
          <textarea id="cf-message" name="message" rows="5" placeholder="What's on your mind?" required></textarea>
        </div>
        <button type="submit" class="submit-btn">Send Message</button>
      </form>

    </div>
  </main>
</Base>

<script>
  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data    = new FormData(/** @type {HTMLFormElement} */ (form));
    const name    = (data.get('name')    ?? '').toString().trim();
    const email   = (data.get('email')   ?? '').toString().trim();
    const message = (data.get('message') ?? '').toString().trim();
    if (!name || !email || !message) return;

    const subject = encodeURIComponent(`Message from ${name}`);
    const body    = encodeURIComponent(`Name: ${name}\nEmail: ${email}\n\n${message}`);
    window.location.href = `mailto:ekaratzaferis@gmail.com?subject=${subject}&body=${body}`;
  });
</script>

<style>
  :global(html),
  :global(body) {
    overflow: auto;
    height: auto;
  }

  .back-nav {
    position: fixed;
    top: 1.8rem;
    left: 2rem;
    z-index: 10;
  }

  .back-nav a {
    font-size: 0.62rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #444;
    transition: color 0.3s;
  }

  .back-nav a:hover {
    color: #f0f0f0;
  }

  main {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 2rem;
  }

  .contact-wrap {
    width: 100%;
    max-width: 640px;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* ── Header ───────────────────────────────────────────────── */

  .contact-header {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .contact-title {
    font-size: clamp(2.2rem, 6vw, 3.6rem);
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #f0f0f0;
  }

  .contact-sub {
    font-size: 0.97rem;
    letter-spacing: 0.04em;
    color: #aaa;
    line-height: 1.7;
  }

  /* ── Link cards ────────────────────────────────────────────── */

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .link-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    background: #080808;
    border: 1px solid #161616;
    border-radius: 6px;
    text-decoration: none;
    transition: border-color 0.25s ease, transform 0.25s ease;
    cursor: pointer;
  }

  .link-card:hover {
    border-color: #2a2a2a;
    transform: translateX(4px);
  }

  .link-label {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #666;
  }

  .link-value {
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    color: #c0c0c0;
    transition: color 0.25s;
  }

  .link-card:hover .link-value {
    color: #f0f0f0;
  }

  /* ── Form ─────────────────────────────────────────────────── */

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  label {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #777;
  }

  input,
  textarea {
    background: #080808;
    border: 1px solid #161616;
    border-radius: 6px;
    padding: 0.85rem 1rem;
    color: #c0c0c0;
    font-family: 'Roboto Condensed', system-ui, sans-serif;
    font-size: 0.97rem;
    letter-spacing: 0.03em;
    outline: none;
    resize: none;
    transition: border-color 0.25s ease;
  }

  input::placeholder,
  textarea::placeholder {
    color: #444;
  }

  input:focus,
  textarea:focus {
    border-color: #303030;
  }

  .submit-btn {
    align-self: flex-start;
    padding: 0.85rem 2rem;
    background: transparent;
    border: 1px solid #252525;
    border-radius: 6px;
    color: #bbb;
    font-family: 'Roboto Condensed', system-ui, sans-serif;
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color 0.25s ease, color 0.25s ease, background 0.25s ease;
  }

  .submit-btn:hover {
    border-color: #555;
    color: #f0f0f0;
    background: #0d0d0d;
  }

  /* ── Mobile ───────────────────────────────────────────────── */

  @media (max-width: 520px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    main {
      padding: 5rem 1.25rem 3rem;
      align-items: flex-start;
    }
  }
</style>
