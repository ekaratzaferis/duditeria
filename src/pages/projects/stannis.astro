---
import Base from '../../layouts/Base.astro';
import StannisCanvas from '../../components/StannisCanvas.astro';
import '../../styles/global.css';
---

<Base
  title="Stannis — Duditeria"
  description="Stannis is a finite state machine workflow engine for serverless Node.js. Durable, storage-agnostic, zero dependencies."
  canonical="https://duditeria.com/projects/stannis"
>
  <nav class="back-nav">
    <a href="/projects">← Projects</a>
  </nav>

  <!-- Section 1: Immersive ThreeJS scene -->
  <section class="scene">
    <StannisCanvas />

    <div class="scene-overlay fade-in">
      <h1 class="title">Stannis</h1>
      <p class="tagline">FSM workflow engine for Node.js</p>
    </div>

    <p class="scroll-hint fade-in-delay-2">scroll ↓</p>
  </section>

  <!-- Section 2: Description -->
  <section class="content">
    <article>
      <div class="block fade-up">
        <h2>What is it</h2>
        <p>
          Stannis is a finite state machine workflow engine built for serverless Node.js.
          It lets you define multi-step flows that survive process restarts, scale across
          distributed workers, and resume from any point — without vendor lock-in or
          runtime dependencies.
        </p>
        <p>
          Think AWS Step Functions, but as a plain JavaScript library you own and run anywhere.
          State persists through a two-method storage adapter — Redis, DynamoDB, in-memory,
          or anything you wire up.
        </p>
      </div>

      <div class="block fade-up">
        <h2>Node types</h2>
        <ul class="nodes">
          <li>
            <span class="node-name">Task</span>
            <span class="node-desc">A sequential work unit. Imports and runs an external module.</span>
          </li>
          <li>
            <span class="node-name">Sequence</span>
            <span class="node-desc">Runs child nodes one after another, in order.</span>
          </li>
          <li>
            <span class="node-name">Parallel</span>
            <span class="node-desc">Fans out to all branches concurrently. Waits for every branch to complete before continuing.</span>
          </li>
          <li>
            <span class="node-name">Race</span>
            <span class="node-desc">Fans out to all branches. The first to complete wins; the rest are abandoned.</span>
          </li>
          <li>
            <span class="node-name">Decision</span>
            <span class="node-desc">Evaluates a condition and routes execution to exactly one branch.</span>
          </li>
        </ul>
      </div>

      <div class="block fade-up">
        <h2>Key traits</h2>
        <ul class="traits">
          <li>Durable across serverless cold starts and process restarts</li>
          <li>Storage-agnostic — bring your own adapter</li>
          <li>Resumable via continuation tokens for human-in-the-loop flows</li>
          <li>Zero runtime dependencies — plain JavaScript, JSDoc-typed</li>
          <li>Node.js 20+</li>
        </ul>
      </div>

      <div class="block fade-up">
        <a
          href="https://github.com/ekaratzaferis/stannis"
          class="gh-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          View on GitHub →
        </a>
      </div>
    </article>
  </section>
</Base>

<style>
  /* Allow scrolling on this page */
  :global(html),
  :global(body) {
    overflow-y: auto;
    height: auto;
  }

  /* ── Back nav ────────────────────────────────────────────────────── */
  .back-nav {
    position: fixed;
    top: 1.8rem;
    left: 2rem;
    z-index: 10;
  }

  .back-nav a {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #000000;
    transition: color 0.25s ease;
  }

  .back-nav a:hover {
    color: #333333;
  }

  /* ── Section 1: Scene ────────────────────────────────────────────── */
  .scene {
    position: relative;
    width: 100%;
    height: 100dvh;
    overflow: hidden;
  }

  .scene-overlay {
    position: absolute;
    bottom: 5rem;
    left: 2.5rem;
    z-index: 1;
    pointer-events: none;
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 7vw, 4.5rem);
    font-weight: 300;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--text-primary);
    text-shadow:
      0 0 20px rgba(255, 255, 255, 0.12),
      0 0 40px rgba(255, 255, 255, 0.06);
  }

  .tagline {
    margin-top: 0.5rem;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-indent: 0.42em;
    color: #fff;
  }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.58rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-muted);
    opacity: 0.5;
    pointer-events: none;
  }

  /* ── Section 2: Content ──────────────────────────────────────────── */
  .content {
    background: #000;
    padding: 6rem 2rem 8rem;
  }

  article {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .block h2 {
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .block p {
    font-size: 0.9rem;
    line-height: 1.8;
    color: #b0b0b0;
    letter-spacing: 0.02em;
  }

  .block p + p {
    margin-top: 1rem;
  }

  /* Node types list */
  .nodes {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .nodes li {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 1.5rem;
    align-items: baseline;
    padding: 1rem 0;
    border-bottom: 1px solid #111;
  }

  .nodes li:first-child {
    border-top: 1px solid #111;
  }

  .node-name {
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-primary);
  }

  .node-desc {
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  /* Key traits list */
  .traits {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .traits li {
    font-size: 0.85rem;
    line-height: 1.6;
    color: #b0b0b0;
    padding-left: 1rem;
    position: relative;
  }

  .traits li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: #333;
  }

  /* GitHub link */
  .gh-link {
    display: inline-block;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid #222;
    border-radius: 2px;
    padding: 0.65rem 1.25rem;
    transition: color 0.25s ease, border-color 0.25s ease;
  }

  .gh-link:hover {
    color: var(--text-primary);
    border-color: #444;
  }

  /* Responsive */
  @media (max-width: 520px) {
    .scene-overlay {
      bottom: 5.5rem;
      left: 1.5rem;
    }

    .content {
      padding: 4rem 1.25rem 6rem;
    }

    .nodes li {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }
  }
</style>
